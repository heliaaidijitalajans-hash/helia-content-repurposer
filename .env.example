# Supabase — Dashboard → Project Settings → API
# Project URL (e.g. https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# anon public key (legacy name in dashboard: "anon" / "public")
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Sunucu tarafı (Storage’tan transkripsiyon dosyası indirmek için). Dashboard → API → service_role — asla istemciye vermeyin.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — optional; if omitted, repurposing returns demo output for local dev
OPENAI_API_KEY=

# Canlı site kökü (Inngest senkron / serveOrigin). Örn: https://helia-content-repurposer.vercel.app
# Boş bırakılırsa Vercel’de VERCEL_URL kullanılır.
NEXT_PUBLIC_APP_URL=

# Inngest — async transkripsiyon kuyruğu. Üretim: https://app.inngest.com → anahtarlar. Yerel: `npm run inngest:dev`
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# İsteğe bağlı anahtar rotasyonu
INNGEST_SIGNING_KEY_FALLBACK=


# İsteğe bağlı: POST body'de userId: "test-user" kullanırken Supabase auth.users içindeki gerçek UUID (veya oturumsuz test istekleri).
# TRANSCRIBE_JOB_USER_ID=

# Pro (video transcription): set public.subscriptions.plan to 'pro' for the user's row
# (Table Editor or SQL). Default is 'free'; migration 005_subscriptions.sql creates rows.
