# =============================================================================
# Vercel Production — öncelikli değişkenler (502/503 önleme)
# =============================================================================
# Sunucu (gizli — istemciye ASLA eklemeyin)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# İstemci (Next.js: tarayıcıda kullanım için NEXT_PUBLIC_ zorunlu)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Notlar:
# - SUPABASE_URL boşsa sunucu NEXT_PUBLIC_SUPABASE_URL ile de çalışır.
# - SUPABASE_ANON_KEY boşsa sunucu NEXT_PUBLIC_SUPABASE_ANON_KEY kullanır.
# - SUPABASE_SERVICE_ROLE_KEY yalnızca sunucu route’larında kullanılır; bundle’a dahil etmeyin.
#
# Kayıt sonrası doğrudan giriş için Supabase Dashboard:
# Authentication → Providers → Email → “Confirm email” KAPALI olsun.

OPENAI_API_KEY=

# =============================================================================
# Uygulama URL (Inngest, OAuth redirect, sunucu fetch)
# Örnek üretim: https://heliaai.online
# =============================================================================
NEXT_PUBLIC_APP_URL=

# =============================================================================
# İsteğe bağlı
# =============================================================================
# Admin paneli (/admin) ve /api/admin/* — varsayılan iki adres (digital + dijital yazımı) + isteğe bağlı ek:
# HELIA_ADMIN_EMAIL=

# /api/repurpose metin kredisi atlama (debug UUID)
# ADMIN_USER_ID=

# Async transkripsiyon (Inngest)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_SIGNING_KEY_FALLBACK=

# Transcribe job test kullanıcısı
# TRANSCRIBE_JOB_USER_ID=
