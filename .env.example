# Supabase — Dashboard → Project Settings → API
# Project URL (e.g. https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# anon public key (legacy name in dashboard: "anon" / "public")
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Sunucu tarafı (Storage’tan transkripsiyon dosyası indirmek için). Dashboard → API → service_role — asla istemciye vermeyin.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — optional; if omitted, repurposing returns demo output for local dev
OPENAI_API_KEY=

# Pro (video transcription): set public.subscriptions.plan to 'pro' for the user's row
# (Table Editor or SQL). Default is 'free'; migration 005_subscriptions.sql creates rows.
