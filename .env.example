# Supabase — Dashboard → Project Settings → API
# Project URL (e.g. https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# anon public key (legacy name in dashboard: "anon" / "public")
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# OpenAI — optional; if omitted, repurposing returns demo output for local dev
OPENAI_API_KEY=

# Pro (video transcription): set public.profiles.plan to 'pro' for the user in Supabase
# (Table Editor or SQL). Default is 'free'; migration 004_profiles_plan.sql creates profiles.
